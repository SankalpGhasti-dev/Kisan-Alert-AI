<!DOCTYPE html><html class="dark" lang="en"><head>
<meta charset="utf-8">
<meta content="width=device-width, initial-scale=1.0" name="viewport">
<title>Kisan Alert AI | Weather Intelligence Center</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&amp;family=Hanken+Grotesk:wght@400;500;600&amp;display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet">
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "on-primary-fixed-variant": "#005313",
                        "on-primary-container": "#003c0b",
                        "surface-container-lowest": "#0a0f0e",
                        "secondary-container": "#feb300",
                        "on-surface-variant": "#becab9",
                        "surface-container-low": "#181d1b",
                        "inverse-surface": "#dfe3e1",
                        "on-tertiary-fixed": "#0b2010",
                        "inverse-on-surface": "#2d3130",
                        "tertiary-fixed-dim": "#b4cdb4",
                        "secondary-fixed-dim": "#ffba38",
                        "on-tertiary": "#203523",
                        "surface-tint": "#78dc77",
                        "outline": "#899484",
                        "tertiary-container": "#89a18a",
                        "surface-dim": "#101413",
                        "on-secondary-fixed": "#281900",
                        "on-error-container": "#ffdad6",
                        "on-error": "#690005",
                        "inverse-primary": "#006e1c",
                        "outline-variant": "#3f4a3c",
                        "primary": "#78dc77",
                        "on-surface": "#dfe3e1",
                        "surface-container-highest": "#313634",
                        "on-secondary-fixed-variant": "#604100",
                        "on-primary": "#00390a",
                        "tertiary": "#b4cdb4",
                        "surface-variant": "#313634",
                        "surface": "#101413",
                        "surface-container-high": "#262b29",
                        "on-tertiary-fixed-variant": "#364c39",
                        "background": "#101413",
                        "secondary-fixed": "#ffdeac",
                        "primary-fixed": "#94f990",
                        "primary-container": "#4caf50",
                        "surface-bright": "#353a38",
                        "on-tertiary-container": "#223726",
                        "surface-container": "#1c211f",
                        "secondary": "#ffd799",
                        "on-secondary": "#432c00",
                        "on-primary-fixed": "#002204",
                        "error-container": "#93000a",
                        "tertiary-fixed": "#d0e9cf",
                        "primary-fixed-dim": "#78dc77",
                        "on-background": "#dfe3e1",
                        "error": "#ffb4ab",
                        "on-secondary-container": "#6a4800"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "xs": "8px",
                        "margin-mobile": "16px",
                        "margin-desktop": "40px",
                        "md": "24px",
                        "base": "4px",
                        "sm": "16px",
                        "lg": "32px",
                        "xl": "48px",
                        "gutter": "20px"
                    },
                    "fontFamily": {
                        "headline-md": ["Manrope"],
                        "body-md": ["Manrope"],
                        "headline-lg": ["Manrope"],
                        "label-sm": ["Hanken Grotesk"],
                        "label-md": ["Hanken Grotesk"],
                        "display-lg": ["Manrope"],
                        "body-lg": ["Manrope"]
                    },
                    "fontSize": {
                        "headline-md": ["24px", {"lineHeight": "32px", "fontWeight": "600"}],
                        "body-md": ["16px", {"lineHeight": "24px", "fontWeight": "400"}],
                        "headline-lg": ["32px", {"lineHeight": "40px", "fontWeight": "600"}],
                        "label-sm": ["12px", {"lineHeight": "16px", "letterSpacing": "0.05em", "fontWeight": "600"}],
                        "label-md": ["14px", {"lineHeight": "20px", "letterSpacing": "0.01em", "fontWeight": "500"}],
                        "display-lg": ["48px", {"lineHeight": "56px", "letterSpacing": "-0.02em", "fontWeight": "700"}],
                        "body-lg": ["18px", {"lineHeight": "28px", "fontWeight": "400"}]
                    }
                },
            },
        }
    </script>
<style>
        body {
            background-color: #101413;
            color: #dfe3e1;
            font-family: 'Manrope', sans-serif;
        }
        .glass-card {
            background: rgba(21, 46, 27, 0.4);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            transition: all 0.3s ease;
        }
        .glass-card:hover {
            background: rgba(21, 46, 27, 0.6);
            border-color: rgba(120, 220, 119, 0.3);
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .chart-container {
            position: relative;
            height: 120px;
            width: 100%;
        }
    </style>
</head>
<body class="flex min-h-screen bg-background">
<!-- Sidebar (Shared Component Style) -->

<!-- Main Content Canvas -->
<main class="flex-1 min-h-screen">
<!-- Top Nav Bar -->
<header class="sticky top-0 z-40 bg-surface-container border-b border-outline-variant px-margin-desktop h-16 flex justify-between items-center w-full max-w-[1440px] mx-auto">
<div class="flex items-center gap-xl">
<div class="md:hidden">
<h2 class="font-headline-md text-headline-md font-bold text-primary">Kisan Alert AI</h2>
</div>
<nav class="hidden md:flex gap-lg items-center">
<a class="font-body-md text-body-md text-on-surface-variant hover:text-on-surface transition-colors" href="#">Dashboard</a>
<a class="font-body-md text-body-md text-on-surface-variant hover:text-on-surface transition-colors" href="#">Disease Detection</a>
<a class="font-body-md text-body-md text-primary border-b-2 border-primary pb-1" href="#">Weather</a>
<a class="font-body-md text-body-md text-on-surface-variant hover:text-on-surface transition-colors" href="#">Market</a>
</nav>
</div>
<div class="flex items-center gap-md">
<button class="flex items-center gap-xs text-primary font-body-md transition-transform active:scale-95">
<span class="material-symbols-outlined">campaign</span>
                    Alerts
                </button>
<div class="flex gap-sm">
<span class="material-symbols-outlined text-on-surface-variant cursor-pointer hover:text-on-surface">notifications</span>
<span class="material-symbols-outlined text-on-surface-variant cursor-pointer hover:text-on-surface">account_circle</span>
</div>
</div>
</header>
<!-- Dashboard Body -->
<section class="p-margin-desktop space-y-lg max-w-[1440px] mx-auto">
<!-- Header Section -->
<div class="flex flex-col md:flex-row md:items-end justify-between gap-md">
<div>
<h1 class="font-display-lg text-display-lg text-on-surface mb-xs">Weather Intelligence Center</h1>
<div class="flex items-center gap-sm text-on-surface-variant">
<div class="flex items-center gap-xs">
<span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">location_on</span>
<span class="font-body-lg text-body-lg">Maharashtra, Kolhapur</span>
</div>
<span class="w-1 h-1 bg-outline-variant rounded-full"></span>
<span class="font-label-md text-label-md">Last updated: 5 mins ago</span>
</div>
</div>
<div class="flex items-center gap-sm">
<div class="bg-secondary-container/20 border border-secondary-container px-md py-sm rounded-xl flex items-center gap-sm animate-pulse">
<span class="material-symbols-outlined text-secondary-container" style="font-variation-settings: 'FILL' 1;">warning</span>
<span class="font-label-md text-label-md text-secondary-container font-bold uppercase tracking-widest">High Rain Alert</span>
</div>
</div>
</div>
<!-- Current Weather Bento Grid -->
<div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-sm">
<!-- Temperature -->
<div class="glass-card rounded-xl p-md flex flex-col items-center justify-center text-center">
<span class="material-symbols-outlined text-primary mb-xs text-[32px]">device_thermostat</span>
<span class="font-label-sm text-label-sm text-on-surface-variant uppercase">Temperature</span>
<p class="font-headline-lg text-headline-lg text-on-surface">32°C</p>
</div>
<!-- Humidity -->
<div class="glass-card rounded-xl p-md flex flex-col items-center justify-center text-center">
<span class="material-symbols-outlined text-primary mb-xs text-[32px]">humidity_percentage</span>
<span class="font-label-sm text-label-sm text-on-surface-variant uppercase">Humidity</span>
<p class="font-headline-lg text-headline-lg text-on-surface">45%</p>
</div>
<!-- Rainfall -->
<div class="glass-card rounded-xl p-md flex flex-col items-center justify-center text-center">
<span class="material-symbols-outlined text-primary mb-xs text-[32px]">rainy</span>
<span class="font-label-sm text-label-sm text-on-surface-variant uppercase">Rainfall</span>
<p class="font-headline-lg text-headline-lg text-on-surface">12mm</p>
</div>
<!-- Wind Speed -->
<div class="glass-card rounded-xl p-md flex flex-col items-center justify-center text-center">
<span class="material-symbols-outlined text-primary mb-xs text-[32px]">air</span>
<span class="font-label-sm text-label-sm text-on-surface-variant uppercase">Wind Speed</span>
<p class="font-headline-lg text-headline-lg text-on-surface">18<span class="text-label-md">km/h</span></p>
</div>
<!-- UV Index -->
<div class="glass-card rounded-xl p-md flex flex-col items-center justify-center text-center">
<span class="material-symbols-outlined text-primary mb-xs text-[32px]">sunny</span>
<span class="font-label-sm text-label-sm text-on-surface-variant uppercase">UV Index</span>
<p class="font-headline-lg text-headline-lg text-on-surface">High</p>
</div>
<!-- ET0 -->
<div class="glass-card rounded-xl p-md flex flex-col items-center justify-center text-center">
<span class="material-symbols-outlined text-primary mb-xs text-[32px]">eco</span>
<span class="font-label-sm text-label-sm text-on-surface-variant uppercase">ET0</span>
<p class="font-headline-lg text-headline-lg text-on-surface">4.5<span class="text-label-md">mm/d</span></p>
</div>
<!-- Soil Moisture -->
<div class="glass-card rounded-xl p-md flex flex-col items-center justify-center text-center">
<span class="material-symbols-outlined text-primary mb-xs text-[32px]">opacity</span>
<span class="font-label-sm text-label-sm text-on-surface-variant uppercase">Soil</span>
<p class="font-headline-lg text-headline-lg text-primary">Exc.</p>
</div>
</div>
<!-- Forecast and Satellite Row -->
<div class="grid grid-cols-1 lg:grid-cols-12 gap-lg">
<!-- Seven Day Forecast -->
<div class="lg:col-span-8 glass-card rounded-xl p-md overflow-hidden">
<div class="flex justify-between items-center mb-md">
<h3 class="font-headline-md text-headline-md text-on-surface flex items-center gap-xs">
<span class="material-symbols-outlined">calendar_month</span>
                            7-Day Forecast
                        </h3>
<button class="text-primary font-label-md hover:underline">Full Report</button>
</div>
<div class="flex overflow-x-auto pb-sm gap-sm no-scrollbar">
<!-- Mon -->
<div class="flex-shrink-0 w-32 glass-card bg-white/5 rounded-xl p-sm flex flex-col items-center text-center space-y-sm">
<span class="font-label-md text-label-md text-on-surface-variant">Mon</span>
<span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">thunderstorm</span>
<div>
<p class="font-headline-sm text-[20px]">32°/24°</p>
<p class="text-[10px] text-secondary font-bold">85% RAIN</p>
</div>
</div>
<!-- Tue -->
<div class="flex-shrink-0 w-32 glass-card bg-white/5 rounded-xl p-sm flex flex-col items-center text-center space-y-sm">
<span class="font-label-md text-label-md text-on-surface-variant">Tue</span>
<span class="material-symbols-outlined text-primary">cloud</span>
<div>
<p class="font-headline-sm text-[20px]">30°/22°</p>
<p class="text-[10px] text-on-surface-variant font-bold">20% RAIN</p>
</div>
</div>
<!-- Wed -->
<div class="flex-shrink-0 w-32 glass-card bg-white/5 rounded-xl p-sm flex flex-col items-center text-center space-y-sm border-primary/20">
<span class="font-label-md text-label-md text-on-surface-variant">Wed</span>
<span class="material-symbols-outlined text-primary">sunny</span>
<div>
<p class="font-headline-sm text-[20px]">34°/25°</p>
<p class="text-[10px] text-on-surface-variant font-bold">5% RAIN</p>
</div>
</div>
<!-- Thu -->
<div class="flex-shrink-0 w-32 glass-card bg-white/5 rounded-xl p-sm flex flex-col items-center text-center space-y-sm">
<span class="font-label-md text-label-md text-on-surface-variant">Thu</span>
<span class="material-symbols-outlined text-primary">sunny</span>
<div>
<p class="font-headline-sm text-[20px]">35°/26°</p>
<p class="text-[10px] text-on-surface-variant font-bold">2% RAIN</p>
</div>
</div>
<!-- Fri -->
<div class="flex-shrink-0 w-32 glass-card bg-white/5 rounded-xl p-sm flex flex-col items-center text-center space-y-sm">
<span class="font-label-md text-label-md text-on-surface-variant">Fri</span>
<span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">cloud_queue</span>
<div>
<p class="font-headline-sm text-[20px]">31°/23°</p>
<p class="text-[10px] text-on-surface-variant font-bold">15% RAIN</p>
</div>
</div>
<!-- Sat -->
<div class="flex-shrink-0 w-32 glass-card bg-white/5 rounded-xl p-sm flex flex-col items-center text-center space-y-sm">
<span class="font-label-md text-label-md text-on-surface-variant">Sat</span>
<span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">rainy</span>
<div>
<p class="font-headline-sm text-[20px]">29°/21°</p>
<p class="text-[10px] text-secondary font-bold">60% RAIN</p>
</div>
</div>
<!-- Sun -->
<div class="flex-shrink-0 w-32 glass-card bg-white/5 rounded-xl p-sm flex flex-col items-center text-center space-y-sm">
<span class="font-label-md text-label-md text-on-surface-variant">Sun</span>
<span class="material-symbols-outlined text-primary">partly_cloudy_day</span>
<div>
<p class="font-headline-sm text-[20px]">30°/22°</p>
<p class="text-[10px] text-on-surface-variant font-bold">30% RAIN</p>
</div>
</div>
</div>
</div>
<!-- Satellite Weather Layer -->
<div class="lg:col-span-4 glass-card rounded-xl p-md flex flex-col relative overflow-hidden group">
<div class="flex justify-between items-center mb-md z-10">
<h3 class="font-headline-md text-headline-md text-on-surface flex items-center gap-xs">
<span class="material-symbols-outlined">satellite_alt</span>
                            Radar
                        </h3>
<span class="bg-primary/20 text-primary px-sm py-1 rounded-full text-[10px] font-bold uppercase tracking-tighter">Live</span>
</div>
<div class="flex-1 rounded-lg overflow-hidden border border-white/10 relative h-48 lg:h-auto">
<div class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-110" data-alt="A sophisticated satellite radar map of a lush agricultural region in Maharashtra, showing real-time cloud movement and rainfall intensity in vivid greens and yellows against a dark, tech-oriented basemap. Subtle weather patterns and topographic details are visible, evoking a professional GIS weather monitoring interface." style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuAMSnbWF7ZoHK-w78DT1HNRVG3XqpXgjPjHOMEGCKq_ODD7ItUe8U1VM9Z6boTZtPDv2SeOU-S37HwQ26oUOEoI65qW6iaMMBO6yqvu3FnLhIF6TrBt26OIjeIQ8E_ZNJnsnXac7XnnnH4JjVEXU2xXPy8uJtgU6dEn8JKg3DQUu5EPbc2w5GFk5OHjWcNpduTejOCOFmOv_TbDdanmgVc_55WSCd3Lw3QNhC23bQVDQrTvW2SGc71eIVPTZw-VIVm_origddNSlrr1')"></div>
<div class="absolute inset-0 bg-gradient-to-t from-background/80 to-transparent"></div>
<div class="absolute bottom-sm left-sm right-sm flex justify-between items-end">
<div class="flex flex-col">
<span class="font-label-sm text-[10px] text-on-surface-variant">PRECIPITATION</span>
<div class="h-2 w-24 bg-gradient-to-r from-blue-500 via-green-500 to-yellow-500 rounded-full"></div>
</div>
<button class="bg-surface-container-high/80 p-xs rounded-md">
<span class="material-symbols-outlined text-primary scale-75">zoom_in_map</span>
</button>
</div>
</div>
</div>
</div>
<!-- Analysis Grid -->
<div class="grid grid-cols-1 lg:grid-cols-12 gap-lg">
<!-- Charts Section (2x2 Grid) -->
<div class="lg:col-span-8 space-y-md">
<h3 class="font-headline-md text-headline-md text-on-surface">Climate Analytics</h3>
<div class="grid grid-cols-1 md:grid-cols-2 gap-md">
<!-- Rainfall Chart -->
<div class="glass-card rounded-xl p-md">
<div class="flex justify-between items-center mb-xs">
<span class="font-label-md text-label-md text-on-surface-variant">Rainfall Forecast (mm)</span>
<span class="text-primary font-bold">12mm Peak</span>
</div>
<div class="chart-container flex items-end gap-1">
<div class="bg-primary/40 w-full h-[20%] rounded-t-sm"></div>
<div class="bg-primary/40 w-full h-[35%] rounded-t-sm"></div>
<div class="bg-primary/60 w-full h-[60%] rounded-t-sm"></div>
<div class="bg-primary/90 w-full h-[85%] rounded-t-sm"></div>
<div class="bg-primary/60 w-full h-[45%] rounded-t-sm"></div>
<div class="bg-primary/30 w-full h-[25%] rounded-t-sm"></div>
<div class="bg-primary/20 w-full h-[15%] rounded-t-sm"></div>
</div>
<div class="flex justify-between mt-xs text-[10px] text-on-surface-variant font-bold">
<span class="">MON</span><span class="">WED</span><span class="">FRI</span><span class="">SUN</span>
</div>
</div>
<!-- Temp Trend -->
<div class="glass-card rounded-xl p-md">
<div class="flex justify-between items-center mb-xs">
<span class="font-label-md text-label-md text-on-surface-variant">Temperature Trends</span>
<span class="text-secondary font-bold">+2°C vs Avg</span>
</div>
<div class="chart-container relative overflow-hidden">
<svg class="w-full h-full" preserveAspectRatio="none" viewBox="0 0 100 40">
<path d="M0,35 Q20,10 40,25 T80,15 T100,30" fill="none" stroke="#78dc77" stroke-width="2"></path>
<path d="M0,35 Q20,10 40,25 T80,15 T100,30 L100,40 L0,40 Z" fill="url(#grad)" opacity="0.2"></path>
<defs>
<linearGradient id="grad" x1="0%" x2="0%" y1="0%" y2="100%">
<stop offset="0%" style="stop-color:#78dc77;stop-opacity:1"></stop>
<stop offset="100%" style="stop-color:#78dc77;stop-opacity:0"></stop>
</linearGradient>
</defs>
</svg>
</div>
<div class="flex justify-between mt-xs text-[10px] text-on-surface-variant font-bold">
<span class="">00:00</span><span class="">08:00</span><span class="">16:00</span><span class="">24:00</span>
</div>
</div>
<!-- Humidity Chart -->
<div class="glass-card rounded-xl p-md">
<div class="flex justify-between items-center mb-xs">
<span class="font-label-md text-label-md text-on-surface-variant">Humidity Levels (%)</span>
<span class="text-primary font-bold">45% Stable</span>
</div>
<div class="chart-container flex items-end gap-1">
<div class="bg-primary/20 w-full h-[50%] rounded-t-sm"></div>
<div class="bg-primary/20 w-full h-[48%] rounded-t-sm"></div>
<div class="bg-primary/30 w-full h-[46%] rounded-t-sm"></div>
<div class="bg-primary/40 w-full h-[45%] rounded-t-sm"></div>
<div class="bg-primary/50 w-full h-[47%] rounded-t-sm"></div>
<div class="bg-primary/60 w-full h-[49%] rounded-t-sm"></div>
<div class="bg-primary/70 w-full h-[52%] rounded-t-sm"></div>
</div>
</div>
<!-- Wind Speed -->
<div class="glass-card rounded-xl p-md">
<div class="flex justify-between items-center mb-xs">
<span class="font-label-md text-label-md text-on-surface-variant">Wind Velocity</span>
<span class="text-secondary font-bold">18km/h Gusts</span>
</div>
<div class="chart-container flex items-center justify-center">
<div class="relative w-24 h-24 rounded-full border-2 border-dashed border-outline-variant flex items-center justify-center">
<span class="material-symbols-outlined text-primary animate-spin" style="animation-duration: 3s;">air</span>
<div class="absolute -top-1 left-1/2 -translate-x-1/2 bg-primary w-2 h-2 rounded-full"></div>
</div>
</div>
</div>
</div>
</div>
<!-- Right Sidebar Content -->
<div class="lg:col-span-4 space-y-lg">
<!-- Agricultural Advisory -->
<div class="glass-card rounded-xl p-md border-primary/20 bg-primary/5">
<h3 class="font-headline-md text-headline-md text-primary mb-md flex items-center gap-xs">
<span class="material-symbols-outlined">psychology</span>
                            Agri-Advisory
                        </h3>
<ul class="space-y-md">
<li class="flex gap-sm">
<span class="material-symbols-outlined text-secondary-container mt-1">water_drop</span>
<div>
<p class="font-label-md text-label-md text-on-surface font-bold">Best Irrigation Timing</p>
<p class="font-body-md text-body-md text-on-surface-variant">18:00 IST (Post-Rain Absorption)</p>
</div>
</li>
<li class="flex gap-sm">
<span class="material-symbols-outlined text-secondary-container mt-1">thermostat</span>
<div>
<p class="font-label-md text-label-md text-on-surface font-bold">Heat Stress Warning</p>
<p class="font-body-md text-body-md text-on-surface-variant">Moderate (Ensure shading for saplings)</p>
</div>
</li>
<li class="flex gap-sm">
<span class="material-symbols-outlined text-primary mt-1">medical_services</span>
<div>
<p class="font-label-md text-label-md text-on-surface font-bold">Crop Advisory</p>
<p class="font-body-md text-body-md text-on-surface-variant">Apply fungicide after rain session</p>
</div>
</li>
<li class="flex gap-sm">
<span class="material-symbols-outlined text-primary mt-1">bug_report</span>
<div>
<p class="font-label-md text-label-md text-on-surface font-bold">Pest Risk</p>
<p class="font-body-md text-body-md text-on-surface-variant">Low (Dry conditions prevailing)</p>
</div>
</li>
</ul>
</div>
<!-- Alerts Panel -->
<div class="glass-card rounded-xl p-md">
<h3 class="font-headline-md text-headline-md text-on-surface mb-md">Active Alerts</h3>
<div class="space-y-sm">
<!-- High Alert -->
<div class="bg-error-container/10 border-l-4 border-error p-sm rounded-r-lg flex gap-sm">
