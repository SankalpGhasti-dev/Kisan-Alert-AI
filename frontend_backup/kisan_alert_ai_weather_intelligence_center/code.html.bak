<span class="material-symbols-outlined text-primary">info</span>
<div>
<p class="font-label-md text-label-md text-on-surface font-bold">New Advisory</p>
<p class="font-label-sm text-label-sm text-on-surface-variant">Weekly planting schedule updated.</p>
</div>
</div>
</div>
</div>
</div>
</div>
</section>
